# Auto-detect text files and normalize line endings
* text=auto

# Force LF for source files
*.ts   text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.astro text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.md   text eol=lf
*.svg  text eol=lf

# Binary files
*.png  binary
*.jpg  binary
*.ico  binary
*.woff2 binary
*.woff binary
