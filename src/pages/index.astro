---
import Layout from '../layouts/Layout.astro';
import { getTodayQuestion } from '../data/questions';

const question = getTodayQuestion();

const today = new Date();
const enDate = today.toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
});
const plDate = today.toLocaleDateString('pl-PL', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
});
---

<Layout lang="en">
  <main>
    <header>
      <h1>Your Daily Reflection</h1>
    </header>

    <section class="card" role="main" aria-label="Today's reflection question">
      <p class="date-label" id="date-label" aria-live="polite">{enDate}</p>
      <p class="question" id="question" lang="en" aria-live="polite">{question.en}</p>
    </section>

    <button class="btn" id="refresh-btn" type="button" aria-label="Show the same question again">
      <svg
        aria-hidden="true"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="1 4 1 10 7 10"></polyline>
        <path d="M3.51 15a9 9 0 1 0 .49-3.51"></path>
      </svg>
      <span id="btn-label">Show again</span>
    </button>

    <div class="lang-switch" role="group" aria-label="Language selection">
      <button class="lang-btn active" id="btn-en" type="button" aria-pressed="true" lang="en"
        >EN</button
      >
      <button class="lang-btn" id="btn-pl" type="button" aria-pressed="false" lang="pl">PL</button>
    </div>

    <footer>
      <p id="footer-text">Take a moment. Breathe. There is no right answer.</p>
    </footer>
  </main>
</Layout>

<script define:vars={{ questionEn: question.en, questionPl: question.pl, enDate, plDate }}>
  const questionEl = document.getElementById('question');
  const dateEl = document.getElementById('date-label');
  const btnLabel = document.getElementById('btn-label');
  const footerText = document.getElementById('footer-text');
  const btnEn = document.getElementById('btn-en');
  const btnPl = document.getElementById('btn-pl');
  const refreshBtn = document.getElementById('refresh-btn');

  const i18n = {
    en: {
      question: questionEn,
      date: enDate,
      btnRefresh: 'Show again',
      footer: 'Take a moment. Breathe. There is no right answer.',
      btnAriaRefresh: 'Show the same question again',
    },
    pl: {
      question: questionPl,
      date: plDate,
      btnRefresh: 'Pokaż jeszcze raz',
      footer: 'Zatrzymaj się. Oddychaj. Nie ma złej odpowiedzi.',
      btnAriaRefresh: 'Pokaż to samo pytanie jeszcze raz',
    },
  };

  // Detect browser / system language
  function detectLang() {
    const saved = localStorage.getItem('ky-lang');
    if (saved === 'en' || saved === 'pl') return saved;
    const nav = (navigator.language || '').toLowerCase();
    return nav.startsWith('pl') ? 'pl' : 'en';
  }

  function setLang(lang) {
    localStorage.setItem('ky-lang', lang);

    const t = i18n[lang];
    questionEl.textContent = t.question;
    questionEl.lang = lang;
    dateEl.textContent = t.date;
    btnLabel.textContent = t.btnRefresh;
    footerText.textContent = t.footer;
    refreshBtn.setAttribute('aria-label', t.btnAriaRefresh);

    btnEn.classList.toggle('active', lang === 'en');
    btnPl.classList.toggle('active', lang === 'pl');
    btnEn.setAttribute('aria-pressed', String(lang === 'en'));
    btnPl.setAttribute('aria-pressed', String(lang === 'pl'));

    document.documentElement.lang = lang;
  }

  function pulse() {
    const card = document.querySelector('.card');
    card.style.transition = 'opacity 0.15s';
    card.style.opacity = '0.4';
    setTimeout(() => {
      card.style.opacity = '1';
    }, 150);
  }

  btnEn.addEventListener('click', () => {
    pulse();
    setLang('en');
  });
  btnPl.addEventListener('click', () => {
    pulse();
    setLang('pl');
  });
  refreshBtn.addEventListener('click', () => {
    pulse();
  });

  setLang(detectLang());
</script>
